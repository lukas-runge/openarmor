{
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "target": "es2020",
        "module": "esnext",
        "moduleResolution": "bundler",
        "declaration": true,
        "outDir": "dist",
        "rootDir": "src",
        "lib": [
            "es2020",
            "dom",
            "dom.iterable"
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}