{
    "compilerOptions": {
        "target": "es5",
        "module": "commonjs",
        "declaration": false,
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": "src",
        "types": [
            "openpnp-types"
        ],
        "lib": [
            "es5"
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}